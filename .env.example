# Copy this to .env and fill in your values
# cp .env.example .env

# PostgreSQL password (choose a strong password)
DB_PASSWORD=change-me-strong-password

# JWT secret (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32

# JWT expiry
JWT_EXPIRES_IN=7d

# Your server's URL (used for CORS)
FRONTEND_URL=http://localhost

# Port to expose on the host (default: 80)
HOST_PORT=80

# Battle rewards (optional, defaults provided)
BATTLE_REWARD_WIN_BASE=200
BATTLE_REWARD_WIN_PER_TURN=50
BATTLE_REWARD_DRAW=100
BATTLE_REWARD_LOSS=50
